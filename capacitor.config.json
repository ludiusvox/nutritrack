{
  "appId": "com.nutritrack.app",
  "appName": "NutriTrack",
  "webDir": "dist", 
  "server": {
    "androidScheme": "http",
    "allowNavigation": ["*"]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#000000"
    },
    "Camera": {
      "permissions": ["camera", "photos"]
    }
  }
}